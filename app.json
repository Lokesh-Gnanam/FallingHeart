{
  "expo": {
    "name": "FallingHearts",
    "slug": "FallingHearts",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "fallinghearts",
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-font",
      "expo-secure-store",
      "expo-status-bar"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.fallinghearts.app"
    }
  }
}
